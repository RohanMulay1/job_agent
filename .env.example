# Anthropic API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Absolute path to the persistent browser profile directory.
# This is where Playwright saves cookies/session after setup_auth.py is run.
# Windows example: C:\Users\YourName\job_agent_profile
USER_DATA_DIR=C:\Users\rohan\job_agent_profile

# Comma-separated job titles to search for
TARGET_TITLES=AI Engineer,ML Engineer,Machine Learning Engineer,LLM Engineer,AI/ML Engineer,Computer Vision Engineer,ADAS Engineer,Autonomous Systems Engineer,Perception Engineer,Agent Engineer,AI Agents Engineer,Agentic AI Engineer,Workflow Automation Engineer,AI Automation Engineer,n8n Developer,Founding Engineer,Founding AI Engineer,Software Engineer,Backend Engineer,Python Developer

# Comma-separated locations (use "Remote" for remote-only)
TARGET_LOCATIONS=Remote,Bangalore,Mumbai

# Maximum applications per run across all platforms
MAX_APPLICATIONS_PER_RUN=10

# Maximum pages to paginate per search query per platform
MAX_PAGES_PER_SEARCH=5

# Comma-separated platforms to enable: indeed,naukri,wellfound
ENABLED_PLATFORMS=indeed,naukri,wellfound

# Run browser in headless mode during apply runs (True/False)
HEADLESS=True

# Minimum LLM job-fit score to apply (0.0 – 1.0)
FIT_THRESHOLD=0.65
